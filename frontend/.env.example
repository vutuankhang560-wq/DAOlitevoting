# Deployed Voting contract address (testnet). Empty disables contract features.
VITE_CONTRACT_ID=

# Deployed governance-token (SEP-41) contract address. Voting reads
# balance(voter) on this token to weight each vote — the L4 inter-contract call.
VITE_GOV_TOKEN_ID=

# Display label + decimals for the governance token (cosmetic / formatting).
VITE_GOV_TOKEN_SYMBOL=DAO
VITE_GOV_TOKEN_DECIMALS=7

# DAO treasury address — receives the L1 "vote fee" XLM payment. Defaults to a
# friendbot-funded placeholder; replace with your own G... address after deploy.
VITE_TREASURY_ADDRESS=
